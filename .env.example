# Cardboard configuration
# Copy this file to .env and adjust as needed.

# Port Cardboard will be available on.
PORT=8000

# Where to store the database on the host machine.
# The default below stores it in the data/ folder next to this file,
# which is inside /mnt/user/appdata/cardboard/ if you followed the README.
DATA_PATH=./data

# Logging level: DEBUG, INFO (default), WARNING, ERROR
# Set to DEBUG temporarily when diagnosing problems; revert to INFO for normal use.
# LOG_LEVEL=INFO

# Comma-separated list of allowed CORS origins. Defaults to * (all origins).
# If Cardboard is exposed to the internet, restrict this to your server's address
# to prevent other websites from making requests to your API on your behalf.
# ALLOWED_ORIGINS=http://192.168.1.100:8000

# Override the data directory path inside the container. You should not need to
# change this unless you are customising the Docker volume mount point.
# DATA_DIR=/app/data
